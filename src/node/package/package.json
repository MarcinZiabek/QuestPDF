{
    "name": "questpdf",
    "version": "0.1.0",
    "description": "QuestPDF fluent API for Node.js: generated TypeScript DSL and koffi bindings over the shared QuestPDF.Native (NativeAOT) library.",
    "license": "MIT",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "!dist/samples"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc",
        "publish-native": "node scripts/publish-native.mjs",
        "pack-feed": "node scripts/pack-feed.mjs",
        "samples": "npm run build && node dist/samples/run-all.js"
    },
    "dependencies": {
        "koffi": "^2.14.1"
    },
    "optionalDependencies": {
        "@questpdf/native-darwin-arm64": "0.1.0",
        "@questpdf/native-darwin-x64": "0.1.0",
        "@questpdf/native-win32-x64": "0.1.0",
        "@questpdf/native-win32-arm64": "0.1.0",
        "@questpdf/native-linux-x64": "0.1.0",
        "@questpdf/native-linux-arm64": "0.1.0",
        "@questpdf/native-linux-musl-x64": "0.1.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "typescript": "^5.6.0"
    }
}
