{
    "name": "questpdf",
    "version": "0.1.0",
    "description": "QuestPDF is a modern PDF generation library for Node.js. Create invoices, reports, and data exports with a fluent, code-first API — an alternative to HTML-to-PDF conversion. Merge and edit documents, generate PDF/A and accessible PDF/UA files. Source-available with a free Community license.",
    "keywords": [
        "pdf",
        "pdf-generation",
        "document",
        "report",
        "invoice",
        "export",
        "merge",
        "accessibility",
        "typescript",
        "fluent",
        "layout"
    ],
    "license": "SEE LICENSE IN LICENSE.md",
    "author": "Marcin Ziąbek (CodeFlint)",
    "homepage": "https://www.questpdf.com",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/QuestPDF/QuestPDF.git"
    },
    "bugs": {
        "url": "https://github.com/QuestPDF/QuestPDF/issues"
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "!dist/samples",
        "!dist/doc-examples"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc",
        "publish-native": "node scripts/publish-native.mjs",
        "pack-feed": "node scripts/pack-feed.mjs",
        "samples": "npm run build && node dist/samples/run-all.js",
        "doc-examples": "npm run build && node --test \"dist/doc-examples/**/*.test.js\""
    },
    "dependencies": {
        "koffi": "^2.14.1"
    },
    "optionalDependencies": {
        "@questpdf/native-darwin-arm64": "0.1.0",
        "@questpdf/native-darwin-x64": "0.1.0",
        "@questpdf/native-win32-x64": "0.1.0",
        "@questpdf/native-win32-arm64": "0.1.0",
        "@questpdf/native-linux-x64": "0.1.0",
        "@questpdf/native-linux-arm64": "0.1.0",
        "@questpdf/native-linux-musl-x64": "0.1.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "typescript": "^5.6.0"
    }
}
